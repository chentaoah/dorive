# EnvironmentPostProcessor
org.springframework.boot.env.EnvironmentPostProcessor=\
com.gitee.dorive.module.v1.impl.environment.ModuleEnvironmentPostProcessor,\
com.gitee.dorive.launcher.v1.configuration.DoriveMybatisPlusConfiguration
# Configuration
org.springframework.boot.autoconfigure.EnableAutoConfiguration=\
com.gitee.dorive.launcher.v1.configuration.DoriveModuleConfiguration,\
com.gitee.dorive.launcher.v1.configuration.DoriveCoreConfiguration,\
com.gitee.dorive.launcher.v1.configuration.DoriveMybatisPlusConfiguration,\
com.gitee.dorive.launcher.v1.configuration.DoriveWebConfiguration